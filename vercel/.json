{
  "git": {
    "deploymentEnabled": {
      "main": true,
      "*": false
    }
  },
  "headers": [
    {
      "source": "/logo.svg",
      "headers": [
        {
          "key": "Access-Control-Allow-Origin",
          "value": "*"
        },
        {
          "key": "Access-Control-Allow-Methods",
          "value": "GET, OPTIONS"
        },
        {
          "key": "Cache-Control",
          "value": "public, max-age=86400, immutable"
        }
      ]
    }
  ]
}
